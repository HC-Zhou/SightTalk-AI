APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

LIVEKIT_URL=ws://localhost:7880
# Optional server-side URL. Use ws://livekit:7880 inside Docker Compose.
LIVEKIT_SERVER_URL=
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM_TTL_SECONDS=3600

# Production default is bailian. Use mock for local demos without Bailian credentials.
AI_PROVIDER=bailian
BAILIAN_API_KEY=
BAILIAN_REGION=cn-beijing
# Optional Bailian application ID. If unavailable or unauthorized, the backend falls back to models below.
BAILIAN_APP_ID=
BAILIAN_APP_API_URL=https://dashscope.aliyuncs.com/api/v1
BAILIAN_COMPATIBLE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_TEXT_MODEL=qwen-plus
BAILIAN_VISION_MODEL=qwen-vl-plus
# Realtime model settings for Qwen-Omni-Realtime WebSocket.
BAILIAN_WORKSPACE_ID=
BAILIAN_MODEL=qwen3-omni-flash-realtime
BAILIAN_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
BAILIAN_TURN_SILENCE_DURATION_MS=2000

DEFAULT_MEDIA_MODE=balanced
ECONOMY_MAX_VIDEO_FPS=0.2
BALANCED_MAX_VIDEO_FPS=1.0
ACCURATE_MAX_VIDEO_FPS=2.0
MAX_JPEG_EDGE=1024
JPEG_QUALITY=75
