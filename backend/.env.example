APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
SIGHTTALK_DATA_DIR=./data
AUTH_SECRET_KEY=dev-auth-secret-at-least-32-bytes-change-me
AUTH_TOKEN_TTL_SECONDS=604800
HARNESS_MEMORY_MAX_ITEMS=20
MEMORY_BACKEND=nanobot
MEMORY_AGENT_ID=sighttalk
MEMORY_SEARCH_LIMIT=5
MEMORY_SEARCH_THRESHOLD=0.3
# Optional legacy Mem0 backend settings. Leave empty for nanobot markdown memory.
MEM0_API_KEY=
MEM0_HOST=
MEM0_LOCAL_CONFIG_JSON=
MEM0_AGENT_ID=sighttalk
MEM0_SEARCH_LIMIT=5
MEM0_SEARCH_THRESHOLD=0.3
SHORT_MEMORY_MAX_MESSAGES=24
SHORT_MEMORY_MAX_ESTIMATED_TOKENS=8000

LIVEKIT_URL=ws://localhost:7880
# Optional server-side URL. Use ws://livekit:7880 inside Docker Compose.
LIVEKIT_SERVER_URL=
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=dev-livekit-secret-at-least-32-bytes-change-me
LIVEKIT_ROOM_TTL_SECONDS=3600

# Production default is bailian. Use mock for local demos without Bailian credentials.
AI_PROVIDER=bailian
BAILIAN_API_KEY=
BAILIAN_REGION=cn-beijing
# Optional Bailian application ID. If unavailable or unauthorized, the backend falls back to models below.
BAILIAN_APP_ID=
BAILIAN_APP_API_URL=https://dashscope.aliyuncs.com/api/v1
BAILIAN_COMPATIBLE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_TEXT_MODEL=qwen-plus
BAILIAN_VISION_MODEL=qwen-vl-plus
# Realtime model settings for Qwen-Omni-Realtime WebSocket.
BAILIAN_WORKSPACE_ID=
BAILIAN_MODEL=qwen3-omni-flash-realtime
BAILIAN_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
BAILIAN_TURN_SILENCE_DURATION_MS=800
AI_MANUAL_RESPONSE_ENABLED=false

DEFAULT_MEDIA_MODE=balanced
ECONOMY_MAX_VIDEO_FPS=0.2
BALANCED_MAX_VIDEO_FPS=0.5
ACCURATE_MAX_VIDEO_FPS=1.0
MAX_JPEG_EDGE=640
JPEG_QUALITY=65
